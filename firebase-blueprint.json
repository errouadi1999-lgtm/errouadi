{
  "entities": {
    "Channel": {
      "title": "Channel",
      "description": "A streamable IPTV channel",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the channel" },
        "category": { "type": "string", "description": "The category of the channel" },
        "streamUrl": { "type": "string", "format": "uri", "description": "The URL of the video stream" },
        "logoUrl": { "type": "string", "format": "uri", "description": "The URL of the channel logo" },
        "description": { "type": "string", "description": "A brief description of the channel" }
      },
      "required": ["name", "category", "streamUrl"]
    }
  },
  "firestore": {
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Collection of IPTV channels"
    }
  }
}
